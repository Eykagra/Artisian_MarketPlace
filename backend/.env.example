# Copy this to .env and fill in your values. Never commit .env to git.

# Database (use Render Postgres internal URL or any hosted Postgres)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_NAME=artisan_market

# Auth
JWT_SECRET=change_this_to_a_long_random_string

# CORS — set to your Vercel frontend URL in production
FRONTEND_URL=https://your-app.vercel.app

# NVIDIA NIM
NIM_API_BASE=https://integrate.api.nvidia.com
NIM_MODEL=deepseek-ai/deepseek-v3.1-terminus
NIM_API_KEY=nvapi-...

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Stripe (test mode)
STRIPE_SECRET_KEY=sk_test_...
